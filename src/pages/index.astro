---
import Layout from "../layout/Layout.astro";
---

<Layout title="Forside">
  <div class="grid1">
    <video class="herovideo" src="/video/hostmonvideo.mp4" autoplay muted
    ></video>
    <div class="circle">
      <h1 class="hostmon_titel">HØST MØN</h1>
      <h2 class="subtitel">28-29 AUGUST</h2>
      <img src="/src/assets/logo/cirkel.png" alt="" />
    </div>
  </div>
</Layout>

<style>
  .herovideo {
    max-width: 1450px;
    grid-row: 1/2;
    grid-column: 1/2;
  }

  .grid1 {
    display: grid;
  }

  .circle {
    grid-row: 1/2;
    grid-column: 1/2;
    display: grid;
    grid-template-rows: 1fr 1fr;
    height: 800px;
    /* background-color: red; */
  }
  .circle img {
    /* max-width: 1000px;
    max-height: auto; */
    grid-row: 1/3;
    grid-column: 1/2;
    place-self: center center;
    /* z-index: -10; */
    /* height: 100%; */
    padding: 30%;
  }

  .hostmon_titel {
    grid-row: 1/2;
    grid-column: 1/2;
    place-self: center;
    z-index: 1;
  }

  .subtitel {
    grid-row: 2/3;
    grid-column: 1/2;
    place-self: center;
    align-self: start;
    z-index: 2;
  }
</style>
