---
const { title, id } = Astro.props;
---

<section {id}>
  <div class="Praktisk_Section">
    <div class="grid_1-1">
      <h2>{title}</h2>
      <div class="Cirkle_element"></div>
    </div>
    <div class="Section_divider"></div>

    <div class="Desktop_grid">
      <div class="text">
        <slot name="text" />
      </div>
      <div>
        <slot name="image" />
        <slot name="link" />
      </div>
    </div>
  </div>
</section>

<style>
  /********* LAYOUT **********/
  .grid_1-1 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .Cirkle_element {
    background-color: var(--section-color);
    width: 30px;
    height: 30px;
    border-radius: 50%;
    box-shadow: 0 0 40px 10px var(--section-color);
    justify-self: end;
    align-self: center;
  }

  section {
    margin: 0rem 1rem 3rem 1rem;
  }

  /********** SECTION DIVIDER ***********/
  .Section_divider {
    height: 2px;
    background-color: var(--text-color);
    width: 100%;
  }

  /********** DESKTOP **********/
  @media (min-width: 801px) {
    .Desktop_grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .Cirkle_element {
      width: 50px;
      height: 50px;
      justify-self: left;
      grid-column: 1/2;
      grid-row: 1/2;
      align-self: center;
    }

    h2 {
      grid-column: 2/3;
      grid-row: 1/2;
    }
  }
</style>
