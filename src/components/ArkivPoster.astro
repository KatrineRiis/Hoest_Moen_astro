---
import ArkivButton from "./ArkivButton.astro";

const { imgSrc, year } = Astro.props;
---

<div class="arkiv_poster">
  <img src={imgSrc} alt={year} class="shape" />
  <ArkivButton text={year} imgSrc={imgSrc} />
</div>

<style>
  .arkiv_poster {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 30px;
  }

  .shape {
    width: 500px;
    height: 500px;
    border-radius: 999px;
    margin: 0 auto;
    filter: drop-shadow(-25px 0px #bde300);
  }
</style>
