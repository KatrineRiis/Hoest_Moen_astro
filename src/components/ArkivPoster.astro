---
import ArkivButton from "./ArkivButton.astro";

const { imgSrc, year } = Astro.props;
---

<div class="arkiv_poster">
  <div class="img_wrapper">
    <div class="circle"></div>
    <img src={imgSrc} alt={year} class="shape" />
  </div>
  <ArkivButton text={year} imgSrc={imgSrc} />
</div>

<style>
  .img_wrapper {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .shape {
    position: relative;
    z-index: 1;
    width: 300px;
    height: auto;
    display: block;
  }

  .circle {
    position: absolute;
    width: 250px;
    height: 250px;
    background: var(--background-color);
    border-radius: 50%;
    top: 50%;
    left: 50%;
    transform: translate(-80%, -50%);
    z-index: 0;
  }
  @media (min-width: 1024px) {
    .arkiv_poster {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: 30px;
    }

    .shape {
      width: 500px;
      height: 500px;
      border-radius: 999px;
      filter: drop-shadow(-25px 0px var(--background-color));
    }
  }
</style>
