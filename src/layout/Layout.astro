---
const { title } = Astro.props;
import "../styles/global.css";
import BilletterPopup from "../components/BilletterPopup.astro";
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="robots" content="noindex" />
    <title>{title}</title>
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="../icons/favIcon3.webp" />

    <!--Font-->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Monoton&family=Roboto:ital,wght@0,100..900;1,100..900&family=Unbounded:wght@200..900&display=swap" rel="stylesheet" />
  </head>

  <body>
    <header>
      <nav>
        <ul class="menu">
          <li><a href="index.html">Program</a></li>

          <li><a href="">Bliv Frivillig</a></li>
          <li><a href="praktisk">Praktisk</a></li>
          <li><a href="omOs">Om os</a></li>
          <li class="Billerter_Burger"><a href="#">Billetter</a></li>
        </ul>
      </nav>

      <a class="Billetter" id="Billet" href="#">Billetter</a>

      <button class="burger" aria-label="Menu">
        <span class="line"></span>
        <span class="line"></span>
        <span class="line"></span>
      </button>
    </header>
    <div class="hide fadeIn" id="Popup">
      <BilletterPopup />
    </div>

    <main>
      <slot />

      <footer>
        <div class="Section_divider"></div>
        <div class="footer_grid_1-1">
          <div>
            <p>Sommerens sidste skrig</p>
            <p>Vender tilbage i 2026</p>
            <p>DET BLIVER HØJT OG SMUKT</p>
          </div>

          <div class="Kontakt">
            <a href="#">info@hoestmoen.dk</a>
            <div class="soMe_icons">
              <img src="../icons/desktop_fb_ikon.webp" alt="Link til Facebook" />
              <img src="../icons/desktop_insta_ikon.webp" alt="Link til Instagram" />
            </div>
          </div>
        </div>
      </footer>
    </main>
  </body>

  <style>
    .hide {
      display: none;
    }

    .fadeIn {
      animation: fadeIn_kf 0.4s linear;
    }

    @keyframes fadeIn_kf {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  </style>

  <script>
    const burger = document.querySelector(".burger");
    const nav = document.querySelector("nav");

    burger.addEventListener("click", burgerClick);
    function burgerClick() {
      burger.classList.toggle("active");
      nav.classList.toggle("active");
    }

    const btn = document.querySelector("#Billet");
    const popup = document.querySelector("#Popup");

    // Åbn popup
    btn.addEventListener("click", (e) => {
      e.stopPropagation(); // 👈 vigtigt
      popup.classList.remove("hide");
    });

    // Klik udenfor → luk popup
    document.addEventListener("click", (e) => {
      if (!popup.contains(e.target)) {
        popup.classList.add("hide");
      }
    });
  </script>
</html>
